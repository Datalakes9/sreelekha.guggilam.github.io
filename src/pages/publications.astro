---
import Layout from "@/layouts/Layout.astro";
import { publications } from "@/data/cv";
import { highlightAuthor } from "@/lib/utils";
const ALL_PAPERS = publications;

// Group publications by year
const publicationsByYear = ALL_PAPERS.reduce((acc, paper) => {
  const year = paper.time;
  if (!acc[year]) {
    acc[year] = [];
  }
  acc[year].push(paper);
  return acc;
}, {});

// Sort years in descending order (most recent first)
const sortedYears = Object.keys(publicationsByYear).sort((a, b) => parseInt(b) - parseInt(a));
---

<Layout title="Publications">
  <div class="prose max-w-none">
    <h1 class="text-3xl font-bold mb-8">Publications</h1>

    <style>
      :global(.highlighted-author) {
        font-weight: bold;
        text-decoration: underline;
      }
    </style>

    {
      sortedYears.map((year) => (
        <div class="mb-12">
          <h2 class="text-2xl font-semibold mb-6 text-accent border-b-2 border-accent pb-2">
            {year}
          </h2>

          <div class="space-y-6">
            {
              publicationsByYear[year].map((paper: any, idx: number) => (
                <div class="card bg-base-200">
                  <div class="card-body">
                    <div class="text-base leading-relaxed">
                      <span set:html={highlightAuthor(paper.authors)} />
                      <span class="font-medium"> ({paper.time}). </span>

                      {paper.doi ? (
                        <a href={`https://doi.org/${paper.doi}`} target="_blank" rel="noopener noreferrer" class="hover:text-accent font-medium">
                          {paper.title}
                        </a>
                      ) : (
                        <span class="font-medium">{paper.title}</span>
                      )}
                      <span>. </span>

                      <span class="italic">{paper.venue}</span>
                      <span>.</span>

                      {paper.doi && (
                        <span> <a href={`https://doi.org/${paper.doi}`} target="_blank" rel="noopener noreferrer" class="text-accent hover:underline text-sm">DOI</a></span>
                      )}
                    </div>

                    {paper.citation && (
                      <div class="card-actions justify-end mt-3">
                        <button
                          class="btn btn-sm btn-outline cite-btn"
                          data-citation={paper.citation}
                          data-modal-id={`cite-modal-${year}-${idx}`}
                        >
                          Cite
                        </button>
                      </div>
                    )}
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      ))
    }
  </div>

  {/* Citation modal */}
  <dialog id="cite-modal" class="modal">
    <div class="modal-box max-w-2xl">
      <h3 class="font-bold text-lg mb-4">Citation</h3>
      <pre id="cite-text" class="bg-base-200 p-4 rounded-lg text-sm whitespace-pre-wrap break-words overflow-x-auto"></pre>
      <div class="modal-action">
        <button id="copy-cite-btn" class="btn btn-accent btn-sm">Copy to Clipboard</button>
        <form method="dialog">
          <button class="btn btn-sm">Close</button>
        </form>
      </div>
    </div>
    <form method="dialog" class="modal-backdrop">
      <button>close</button>
    </form>
  </dialog>
</Layout>

<script>
  document.addEventListener("DOMContentLoaded", setupCiteButtons);
  document.addEventListener("astro:after-swap", setupCiteButtons);

  function setupCiteButtons() {
    const modal = document.getElementById("cite-modal") as HTMLDialogElement;
    const citeText = document.getElementById("cite-text")!;
    const copyBtn = document.getElementById("copy-cite-btn")!;

    document.querySelectorAll(".cite-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const citation = (btn as HTMLElement).dataset.citation || "";
        citeText.textContent = citation;
        modal.showModal();
      });
    });

    copyBtn.addEventListener("click", () => {
      const text = citeText.textContent || "";
      navigator.clipboard.writeText(text).then(() => {
        copyBtn.textContent = "Copied!";
        setTimeout(() => {
          copyBtn.textContent = "Copy to Clipboard";
        }, 2000);
      });
    });
  }
</script>
