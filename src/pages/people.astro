---
import Layout from "@/layouts/Layout.astro";
import PeopleProfileCard from '@/components/PeopleProfileCard.astro';
import anshikaPhoto from '@/assets/anshika_rani.jpg';
import madhaviPhoto from '@/assets/madhavi_pagare.jpg';
import yejinPhoto from '@/assets/yejin_hwang.jpeg';
import type { Person } from '@/types/people';

// Current members by category
const currentPostdoc: Person[] = [
    {
        name: "Madhavi Pagare",
        title: "Postdoctoral Research Associate",
        bio: "Madhavi Pagare is a Postdoctoral Research Associate at Texas A&M University-Corpus Christi. Her research focuses on causal analysis in social determinants of mental health for opioid use disorder, NLP-driven extraction from clinical notes, and predicting mental health determinants through AI techniques. She integrates advanced frameworks such as Siamese Neural Networks and Clinical-Longformer models to bridge healthcare data mining and mental health research.",
        photoAsset: madhaviPhoto,
        cvPath: `${import.meta.env.BASE_URL}pdfs/MADHAVI PAGARE _CV.pdf`,
    },
];

const currentPhd: Person[] = [
    {
        name: "Anshika Rani",
        title: "PhD Student, Coastal and Marine Sciences",
        bio: "Anshika Rani is a PhD student in Coastal and Marine Sciences at Texas A&M University-Corpus Christi. She holds an M.Sc. in Mathematics from NIT Jalandhar, where her thesis focused on solving the Black-Scholes equation using Physics-Informed Neural Networks. Her current research bridges mathematics and AI for environmental and marine science applications, with a focus on deep learning, knowledge distillation, and high-performance computing.",
        photoAsset: anshikaPhoto,
        cvPath: `${import.meta.env.BASE_URL}pdfs/Resume_Anshika.pdf`,
    },
    {
        name: "Jahnavi Krishna Koda",
        title: "PhD Student (Committee Member)",
    },
    {
        name: "Nene Coulibaly",
        title: "PhD Student (Committee Member)",
    },
];

const currentMasters: Person[] = [
    {
        name: "Yejin Hwang",
        title: "Graduate Research & Teaching Assistant",
        bio: "Yejin Hwang is a Master's student in Data Science at Texas A&M University-Corpus Christi with a 4.0 GPA and a Graduate Fellowship. Her research interests include trustworthy and fair ML, behavior-aware modeling, and sentiment and social signal analysis. Her thesis develops a multimodal forecasting system integrating Reddit sentiment and volatility features for financial time-series prediction. She previously worked as a Data Science Researcher at Samsung Medical Center.",
        photoAsset: yejinPhoto,
        cvPath: `${import.meta.env.BASE_URL}pdfs/CV_yejin_hwang_1215.pdf`,
    },
    {
        name: "Vigneshwar Lokoji",
        title: "Masters Student",
    },
];

// Alumni by category
const alumniMasters: Person[] = [
    {
        name: "Nikitha Gugulothu",
        title: "Masters Alumni — First Appointment: Oak Ridge National Laboratory",
    },
];

const alumniUndergrad: Person[] = [
    {
        name: "Tri Do",
        title: "Undergrad Alumni — First Appointment: Ph.D at Oden Institute, UT Austin",
    },
    {
        name: "Mikolaj Jakowski",
        title: "Undergrad Alumni — University of Tennessee, Knoxville",
    },
];

const alumniHighschool: Person[] = [
    {
        name: "Ruhaan Singh",
        title: "High School Alumni — Farragut High School (2022-2024)",
    },
];

// Build sections, filtering out empty ones
const currentSections = [
    { label: "Postdoctoral Researchers", people: currentPostdoc },
    { label: "PhD Students", people: currentPhd },
    { label: "Masters Students", people: currentMasters },
].filter(s => s.people.length > 0);

const alumniSections = [
    { label: "Masters Alumni", people: alumniMasters },
    { label: "Undergraduate Alumni", people: alumniUndergrad },
    { label: "High School Alumni", people: alumniHighschool },
].filter(s => s.people.length > 0);
---

<Layout title="People">
  <div class="prose max-w-none">
    <h1 class="text-3xl font-bold mb-8">People</h1>

    <section class="mb-16">
      <h2 class="text-2xl font-bold border-b-2 border-accent pb-2 mb-8">Current Members</h2>
      {currentSections.map(({ label, people }) => (
        <div class="mb-12">
          <h3 class="text-xl font-semibold mb-6 text-accent">{label}</h3>
          {people.map((person) => (
            <PeopleProfileCard person={person} />
          ))}
        </div>
      ))}
    </section>

    {alumniSections.length > 0 && (
      <section class="mb-16">
        <h2 class="text-2xl font-bold border-b-2 border-accent pb-2 mb-8">Alumni</h2>
        {alumniSections.map(({ label, people }) => (
          <div class="mb-12">
            <h3 class="text-xl font-semibold mb-6 text-accent">{label}</h3>
            {people.map((person) => (
              <PeopleProfileCard person={person} />
            ))}
          </div>
        ))}
      </section>
    )}

    <div class="pt-8">
        <h2 class="text-2xl font-bold mb-4">Joining the Team</h2>
        <div class="card bg-base-100 border border-base-content/10">
            <div class="card-body">
                <p class="text-lg">If you are interested in joining the research group as a student or collaborator, please check the <a href={import.meta.env.BASE_URL} class="text-accent hover:underline">Open Positions</a> section on the Home page.</p>
            </div>
        </div>
    </div>

  </div>
</Layout>
