---
import Layout from '@/layouts/Layout.astro'
import { experiences, education, grants, teaching, mentorship, talks, awards, service, memberships, skills } from '../data/cv'
import CvTimeline from '@/components/ui/CvTimeline.astro'

const orderElement = <T extends { time: string }>(a: T, b: T) => {
  const presentValues = ['present', 'now', 'current', 'today']
  if (presentValues.includes((a['time'] as string)?.split(' - ')[1]?.toLowerCase())) return -1
  const dateA = new Date((a['time'] as string)?.split(' - ')[1])
  const dateB = new Date((b['time'] as string)?.split(' - ')[1])
  return dateB.getTime() - dateA.getTime()
}

const orderdExperiences = experiences.sort((a, b) => orderElement(a, b))
const orderdEducations = education.sort((a, b) => orderElement(a, b))
---

<Layout title="CV">

	<div class="flex justify-end mb-6">
		<a href={`${import.meta.env.BASE_URL}pdfs/Sreelekha_Guggilam_CV.pdf`} target="_blank" class="btn btn-accent btn-sm">Download CV (PDF)</a>
	</div>

	{orderdExperiences.length > 0 && (
		<section class="mb-12">
			<h2 class="text-2xl font-bold mb-6 border-b pb-2">Experience</h2>
			<CvTimeline elements={orderdExperiences} colored={true} />
		</section>
	)}

	{orderdEducations.length > 0 && (
		<section class="mb-12">
			<h2 class="text-2xl font-bold mb-6 border-b pb-2">Education</h2>
			<CvTimeline elements={orderdEducations} colored={true} />
		</section>
	)}

	{grants.length > 0 && (
		<section class="mb-12">
			<h2 class="text-2xl font-bold mb-6 border-b pb-2">Grant Support</h2>
			<div class="space-y-4">
				{grants.map((g) => (
					<div class="card bg-base-200">
						<div class="card-body py-4">
							<div class="flex justify-between items-start flex-wrap gap-2">
								<div>
									<h3 class="font-bold">{g.title}</h3>
									<p class="text-sm text-base-content/80">{g.project}</p>
									<p class="text-sm"><span class="font-medium">Role:</span> {g.role}</p>
								</div>
								<div class="text-right">
									<span class="badge badge-accent">{g.amount}</span>
									<p class="text-sm text-base-content/70 mt-1">{g.time}</p>
								</div>
							</div>
						</div>
					</div>
				))}
			</div>
		</section>
	)}

	{teaching.length > 0 && (
		<section class="mb-12">
			<h2 class="text-2xl font-bold mb-6 border-b pb-2">Teaching</h2>
			<div class="overflow-x-auto">
				<table class="table table-zebra">
					<thead>
						<tr>
							<th>Course</th>
							<th>Title</th>
							<th>Semester</th>
							<th>Institution</th>
						</tr>
					</thead>
					<tbody>
						{teaching.map((t) => (
							<tr>
								<td class="font-mono text-sm">{t.course}</td>
								<td>{t.title}</td>
								<td>{t.semester}</td>
								<td>{t.institution}{t.role ? ` (${t.role})` : ''}</td>
							</tr>
						))}
					</tbody>
				</table>
			</div>
		</section>
	)}

	<section class="mb-12">
		<h2 class="text-2xl font-bold mb-6 border-b pb-2">Mentorship</h2>
		<div class="space-y-4">
			{[
				{ label: "Postdoc Mentees", items: mentorship.postdoc },
				{ label: "PhD Advisees", items: mentorship.phd },
				{ label: "Masters Advisees", items: mentorship.masters },
				{ label: "Undergraduate Advisees", items: mentorship.undergrad },
				{ label: "High School Advisees", items: mentorship.highschool },
			].map(({ label, items }) => items.length > 0 && (
				<div>
					<h3 class="font-bold text-lg mb-2">{label}</h3>
					<ul class="list-disc list-inside space-y-1">
						{items.map((m: any) => (
							<li class="text-base-content/90">
								{m.name}
								{m.role ? ` (${m.role})` : ''}
								{m.institution ? `, ${m.institution}` : ''}
								{m.note ? ` — ${m.note}` : ''}
								<span class="text-base-content/60 text-sm ml-2">{m.time}</span>
							</li>
						))}
					</ul>
				</div>
			))}
		</div>
	</section>

	{talks.length > 0 && (
		<section class="mb-12">
			<h2 class="text-2xl font-bold mb-6 border-b pb-2">Talks & Presentations</h2>
			<ul class="space-y-3">
				{talks.map((t) => (
					<li class="flex justify-between items-start gap-4">
						<div>
							<span class="font-medium">{t.title}</span>
							<span class="text-base-content/70">, {t.venue}</span>
						</div>
						<span class="badge badge-outline badge-sm whitespace-nowrap">{t.year}</span>
					</li>
				))}
			</ul>
		</section>
	)}

	{awards.length > 0 && (
		<section class="mb-12">
			<h2 class="text-2xl font-bold mb-6 border-b pb-2">Awards & Scholarships</h2>
			<ul class="space-y-2">
				{awards.map((a) => (
					<li class="flex justify-between items-start gap-4">
						<span>{a.title}</span>
						<span class="badge badge-outline badge-sm whitespace-nowrap">{a.year}</span>
					</li>
				))}
			</ul>
		</section>
	)}

	<section class="mb-12">
		<h2 class="text-2xl font-bold mb-6 border-b pb-2">Professional Service</h2>

		<h3 class="font-bold text-lg mb-2">Organising Committees</h3>
		<ul class="space-y-2 mb-6">
			{service.committees.map((c) => (
				<li class="flex justify-between items-start gap-4">
					<span>{c.title}</span>
					<span class="badge badge-outline badge-sm whitespace-nowrap">{c.year}</span>
				</li>
			))}
		</ul>

		<h3 class="font-bold text-lg mb-2">Referee Service</h3>
		<p class="text-base-content/80 mb-6">{service.referee.join(', ')}</p>

		<h3 class="font-bold text-lg mb-2">Panel Judge</h3>
		<ul class="space-y-2">
			{service.judge.map((j) => (
				<li class="flex justify-between items-start gap-4">
					<span>{j.title}</span>
					<span class="badge badge-outline badge-sm whitespace-nowrap">{j.year}</span>
				</li>
			))}
		</ul>
	</section>

	{memberships.length > 0 && (
		<section class="mb-12">
			<h2 class="text-2xl font-bold mb-6 border-b pb-2">Professional Memberships</h2>
			<ul class="space-y-2">
				{memberships.map((m) => (
					<li class="flex justify-between items-start gap-4">
						<span>{m.org}</span>
						<span class="text-base-content/60 text-sm whitespace-nowrap">{m.time}</span>
					</li>
				))}
			</ul>
		</section>
	)}

	{skills.length > 0 && (
		<section class="mb-12">
			<h2 class="text-2xl font-bold mb-6 border-b pb-2">Technical Skills</h2>
			<div class="space-y-3">
				{skills.map((s) => {
					const [category, ...rest] = s.split(':');
					return (
						<div>
							<span class="font-bold">{category}:</span>
							<span class="text-base-content/80">{rest.join(':')}</span>
						</div>
					);
				})}
			</div>
		</section>
	)}

</Layout>
